@article{ipsita2020storymakar,
  title  = {StoryMakAR: Bringing Stories to Life with an Augmented Reality \& Physical Prototyping Toolkit for Youth},
  author = {Ananya Ipsita and Convergence Accelerator and Convergence Accelerator Phase I and Future of Work and Future of Work and Industrial Innovation and Partnerships},
