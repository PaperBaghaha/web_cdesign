  title     = {PCS: Prominent Cross-Sections for Mesh Models},
  author    = {Subramani Sellamani and Ramanathan Muthuganapathy and Yagnanarayanan Kalyanaraman and Sundar Murugappan and Manish Goyal and Karthik Ramani and Christoph M. Hoffman},
  journal = {Computer-Aided Design and Applications},
