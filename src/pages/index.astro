<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

/* ── Hero entrance ── */
gsap.from('#h-eyebrow',{y:20,autoAlpha:0,duration:.7,delay:.15,ease:'power3.out'});
gsap.from('#h-title',  {y:70,autoAlpha:0,duration:1.1,delay:.3, ease:'power4.out'});
gsap.from('#h-sub',    {y:20,autoAlpha:0,duration:.7, delay:.7, ease:'power3.out'});
gsap.from('#h-cta',    {y:15,autoAlpha:0,duration:.6, delay:.9, ease:'power3.out'});
gsap.from('#h-stats',  {y:30,autoAlpha:0,duration:.8, delay:1.1,ease:'power3.out'});

/* count-up */
document.querySelectorAll('.sstat-n').forEach(function(el) {
  var raw = (el as HTMLElement).dataset.val || '';
  var num = parseInt(raw.replace(/\D/g,''));
  var sfx = raw.replace(/\d/g,'');
  if (!num) return;
  el.textContent = '0'+sfx;
  gsap.to({v:0},{v:num,duration:1.8,delay:1.2,ease:'power2.out',
    onUpdate:function(){ el.textContent=Math.round((this.targets()[0] as any).v)+sfx; }
  });
});

/* ── Continuous floating on named elements ── */
function fl(sel:string,y:number,x:number,r:number,dur:number,del:number){
  var els = document.querySelectorAll(sel);
  if (!els.length) return;
  gsap.to(sel,{y,x,rotation:r,duration:dur,delay:del,ease:'sine.inOut',repeat:-1,yoyo:true});
}
fl('#h-d1',  -16, 0,  10,  4.2, 0  );
fl('#h-d2',  -10, 0, -7,   5.1, .6 );
fl('#h-d3',  -10, 0,  7,   5.4, 1  );
fl('#h-d4',  -8,  0,  14,  3.8, .2 );
fl('#h-d5',  -8,  0, -14,  4.0, .9 );
fl('#h-blade',-20, 0, .5,  5.5, .3 );
fl('#r-d1',  -12, 0,  9,   4.5, .1 );
fl('#r-d2',  -9,  0, -7,   5.0, .8 );
