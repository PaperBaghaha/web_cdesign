---
import SocialLinks from '@components/SocialLinks.astro';
import { site } from '@config/site';
import Base from '@layouts/Base.astro';
import { getAuthors, getBoolField, getTitle, getVenue, getYear, parseBibtex } from '@utils/bibtex';
import { getCollection, render } from 'astro:content';

import AboutContent from '../data/about.mdx';
import bibRaw from '../data/papers.bib?raw';

const allAnnouncements = site.announcements.enabled
  ? (await getCollection('announcements'))
      .filter((e) => !e.data.hidden)
      .sort((a, b) => {
        if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
        return b.data.date.getTime() - a.data.date.getTime();
      })
      .slice(0, site.announcements.limit)
  : [];

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const bibEntries = parseBibtex(bibRaw);
const selectedPapers = site.selectedPapers.enabled
  ? bibEntries.filter((e) => getBoolField(e, 'selected'))
  : [];

const peopleCount = (await getCollection('people')).length;
const researchAreas = (await getCollection('projects')).sort(
  (a, b) => a.data.importance - b.data.importance,
);
const pubYears = bibEntries.map((e) => getYear(e)).filter((y) => y > 1900);
const yearsActive = pubYears.length > 0 ? new Date().getFullYear() - Math.min(...pubYears) : 0;

const renderedAnnouncements = await Promise.all(
  allAnnouncements.map(async (item) => ({ item, rendered: await render(item) })),
);
---

<Base isHome={true}>
  <!-- ═══ HERO — full bleed ═══════════════════════════════════════════════════ -->
  <section class="hero-bleed">
    <!-- Left rail: vertical label -->
    <div class="side-rail side-rail-left" aria-hidden="true">
      <span class="rail-text">PURDUE UNIVERSITY · WEST LAFAYETTE · IN</span>
      <div class="rail-line"></div>
      <span class="rail-year">EST. 2008</span>
    </div>

    <!-- Right rail: vertical label -->
    <div class="side-rail side-rail-right" aria-hidden="true">
      <span class="rail-text">CONVERGENCE DESIGN LAB · CDL</span>
      <div class="rail-line"></div>
      <span class="rail-year">ME · HCI · AI</span>
    </div>

    <!-- Centre content -->
    <div class="hero-content page-container">
      <!-- Eyebrow -->
      <p class="hero-eyebrow" data-reveal>Directed by Prof. Karthik Ramani</p>

      <!-- Giant title -->
      <h1 class="hero-title" data-reveal style="--reveal-delay:0.05s">
        <span class="title-word">Convergence</span><br />
        <span class="title-word">Design</span>
        <span class="title-word title-word-light">Lab</span>
      </h1>

      <!-- Sub row: chips + geo -->
      <div class="hero-sub-row" data-reveal style="--reveal-delay:0.1s">
        <!-- Chips left -->
        <div class="chip-col">
          <p class="hero-sub-label">Research Areas</p>
          <div class="chip-row">
            {
              researchAreas.map((p) => (
                <a class="chip" href={`${site.base}/projects/${p.id}/`}>
                  {p.data.title}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Geo right -->
        <div class="geo-frame" aria-hidden="true">
          <div class="geo-ring geo-ring-outer"></div>
          <div class="geo-ring geo-ring-inner"></div>
          <div class="geo-cross-h"></div>
          <div class="geo-cross-v"></div>
          <div class="geo-arc"></div>
          <div class="geo-monogram">CDL</div>
          <div class="geo-corner geo-corner-tl"></div>
          <div class="geo-corner geo-corner-tr"></div>
          <div class="geo-corner geo-corner-bl"></div>
          <div class="geo-corner geo-corner-br"></div>
          <span class="geo-dot" style="top:10%;left:72%;"></span>
          <span class="geo-dot" style="top:80%;left:16%;"></span>
          <span class="geo-dot geo-dot-ring" style="top:68%;left:74%;"></span>
          <span class="geo-dot" style="top:20%;left:22%;"></span>
          <span class="geo-dot geo-dot-ring" style="top:35%;left:80%;"></span>
        </div>
      </div>
    </div>

    <!-- Bottom tick rule (full bleed) -->
    <div class="tick-rule" aria-hidden="true">
      {
        Array.from({ length: 24 }).map((_, i) => (
          <span class="tick" data-major={i % 6 === 0 ? '' : undefined} />
        ))
      }
    </div>
  </section>

  <!-- ═══ STATS BAR ════════════════════════════════════════════════════════════ -->
  <section class="stats-bar page-container" data-reveal>
    <a class="stat-item" href={`${site.base}/publications/`}>
      <span class="stat-n" data-countup={bibEntries.length} data-suffix="+"
        >{bibEntries.length}+</span
      >
      <span class="stat-l">Publications</span>
    </a>
    <div class="stat-div" aria-hidden="true"></div>
    <a class="stat-item" href={`${site.base}/projects/`}>
      <span class="stat-n" data-countup={researchAreas.length}>{researchAreas.length}</span>
      <span class="stat-l">Research Areas</span>
    </a>
    <div class="stat-div" aria-hidden="true"></div>
    <a class="stat-item" href={`${site.base}/people/`}>
      <span class="stat-n" data-countup={peopleCount}>{peopleCount}</span>
      <span class="stat-l">Lab Members</span>
    </a>
    <div class="stat-div" aria-hidden="true"></div>
    <a class="stat-item" href={`${site.base}/news/`}>
      <span class="stat-n" data-countup={yearsActive} data-suffix="+">{yearsActive}+</span>
      <span class="stat-l">Years Active</span>
    </a>
    <div class="stat-social">
      <SocialLinks />
    </div>
  </section>

  <!-- ═══ ABOUT ════════════════════════════════════════════════════════════════ -->
  <section class="two-col-section page-container" data-reveal>
    <div class="col-label">
      <span class="col-tag">About</span>
      <div class="col-tag-rule"></div>
    </div>
    <div class="col-body prose">
      <AboutContent />
    </div>
  </section>

  <!-- ═══ NEWS ════════════════════════════════════════════════════════════════ -->
  {
    site.announcements.enabled && renderedAnnouncements.length > 0 && (
      <section class="two-col-section page-container" data-reveal>
        <div class="col-label">
          <a class="col-tag col-tag-link" href={`${site.base}/news/`}>
            News
          </a>
          <div class="col-tag-rule" />
          <a class="col-more" href={`${site.base}/news/`}>
            All →
          </a>
        </div>
        <table class="news-tbl">
          <tbody>
            {renderedAnnouncements.map(({ item, rendered: { Content } }) => (
              <tr class="news-row">
                <td class="news-date">{formatDate(item.data.date)}</td>
                <td class="news-body">
                  {item.data.title ? (
                    <a href={`${site.base}/news/${item.data.slug ?? item.id}/`}>
                      {item.data.title}
                    </a>
                  ) : (
                    <Content />
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )
  }

  <!-- ═══ SELECTED PUBLICATIONS ════════════════════════════════════════════════ -->
  {
    site.selectedPapers.enabled && selectedPapers.length > 0 && (
      <section class="two-col-section page-container" data-reveal>
        <div class="col-label">
          <a class="col-tag col-tag-link" href={`${site.base}/publications/`}>
            Selected Publications
          </a>
          <div class="col-tag-rule" />
          <a class="col-more" href={`${site.base}/publications/`}>
            All {bibEntries.length}+ →
          </a>
        </div>
        <ol class="pub-list">
          {selectedPapers.map((entry) => {
            const title = getTitle(entry);
            const authors = getAuthors(entry);
            const venue = getVenue(entry);
            const year = getYear(entry);
            const abbr = entry.fields.abbr;
            const url =
              entry.fields.html ?? (entry.fields.doi ? `https://doi.org/${entry.fields.doi}` : '');
            return (
              <li class="pub-item">
                {abbr && <span class="pub-badge">{abbr}</span>}
                {url ? (
                  <a class="pub-title" href={url} target="_blank" rel="noopener noreferrer">
                    {title}
                  </a>
                ) : (
                  <strong class="pub-title">{title}</strong>
                )}
                <span class="pub-meta">
                  {authors}
                  {(venue || year) && (
                    <>
                      {' '}
                      ·{' '}
                      <em>
                        {venue}
                        {venue && year ? ', ' : ''}
                        {year || ''}
                      </em>
                    </>
                  )}
                </span>
              </li>
            );
          })}
        </ol>
      </section>
    )
  }
</Base>

<style>
  /* ── Fonts ───────────────────────────────────────────────────────────── */
  h1,
  h2,
  .col-tag,
  .stat-n,
  .hero-eyebrow,
  .chip,
  .rail-text,
  .rail-year,
  .geo-monogram,
  .stat-l {
    font-family: 'Space Grotesk', system-ui, sans-serif;
  }

  /* ══ HERO BLEED ═════════════════════════════════════════════════════════ */

  .hero-bleed {
    position: relative;
    width: 100%;
    padding-top: 2.5rem;
    padding-bottom: 0;
    overflow: hidden;
  }

  /* ── Side rails ─────────────────────────────────────────────────────── */

  .side-rail {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.5rem;
    padding-bottom: 1rem;
    z-index: 1;
  }

  .side-rail-left {
    left: 0.75rem;
  }
  .side-rail-right {
    right: 0.75rem;
  }

  .rail-text {
    font-size: 0.52rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-silver-dark);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  .side-rail-right .rail-text {
    transform: none;
  }

  .rail-line {
    flex: 1;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-silver-dark) 20%,
      var(--color-silver-dark) 80%,
      transparent
    );
  }

  .rail-year {
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-silver-dark);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .side-rail-right .rail-year {
    transform: none;
  }

  /* Hide rails below 900px where they overlap content */
  @media (max-width: 900px) {
    .side-rail {
      display: none;
    }
  }

  /* ── Hero centre ─────────────────────────────────────────────────────── */

  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 2.5rem;
  }

  .hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-silver);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    margin: 0 0 2.5rem;
    line-height: 0.92;
    letter-spacing: -0.03em;
  }

  .title-word {
    display: inline;
    font-size: clamp(4rem, 9.5vw, 10rem);
    font-weight: 700;
    color: var(--global-text-color);
  }

  .title-word-light {
    font-weight: 300;
    color: var(--color-silver);
    padding-left: 0.18em;
  }

  /* ── Sub row ──────────────────────────────────────────────────────────── */

  .hero-sub-row {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: center;
  }

  @media (max-width: 860px) {
    .hero-sub-row {
      grid-template-columns: 1fr;
    }
    .geo-frame {
      display: none;
    }
  }

  .hero-sub-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-silver-dark);
    margin-bottom: 0.6rem;
  }

  /* ── Geometric composition ───────────────────────────────────────────── */

  .geo-frame {
    position: relative;
    width: 260px;
    height: 260px;
    margin-left: auto;
  }

  .geo-ring {
    position: absolute;
    border-radius: 50%;
  }

  .geo-ring-outer {
    inset: 0;
    border: 1px solid var(--color-silver-dark);
    animation: spin 50s linear infinite;
  }

  .geo-ring-inner {
    inset: 22%;
    border: 1px dashed var(--color-silver-dark);
    animation: spin 30s linear infinite reverse;
  }

  .geo-arc {
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    border: 1px solid transparent;
    border-top-color: var(--color-silver);
    border-right-color: var(--color-silver);
    animation: spin 8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .geo-cross-h,
  .geo-cross-v {
    position: absolute;
    background: var(--color-silver-dark);
  }
  .geo-cross-h {
    top: 50%;
    left: 18%;
    right: 18%;
    height: 1px;
    transform: translateY(-50%);
  }
  .geo-cross-v {
    left: 50%;
    top: 18%;
    bottom: 18%;
    width: 1px;
    transform: translateX(-50%);
  }

  .geo-monogram {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    background: linear-gradient(135deg, var(--global-text-color) 30%, var(--color-silver) 70%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .geo-corner {
    position: absolute;
    width: 12px;
    height: 12px;
  }
  .geo-corner::before,
  .geo-corner::after {
    content: '';
    position: absolute;
    background: var(--color-silver);
  }
  .geo-corner-tl {
    top: 0;
    left: 0;
  }
  .geo-corner-tl::before {
    top: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
  }
  .geo-corner-tl::after {
    top: 0;
    left: 0;
    width: 1.5px;
    height: 100%;
  }
  .geo-corner-tr {
    top: 0;
    right: 0;
  }
  .geo-corner-tr::before {
    top: 0;
    right: 0;
    width: 100%;
    height: 1.5px;
  }
  .geo-corner-tr::after {
    top: 0;
    right: 0;
    width: 1.5px;
    height: 100%;
  }
  .geo-corner-bl {
    bottom: 0;
    left: 0;
  }
  .geo-corner-bl::before {
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
  }
  .geo-corner-bl::after {
    bottom: 0;
    left: 0;
    width: 1.5px;
    height: 100%;
  }
  .geo-corner-br {
    bottom: 0;
    right: 0;
  }
  .geo-corner-br::before {
    bottom: 0;
    right: 0;
    width: 100%;
    height: 1.5px;
  }
  .geo-corner-br::after {
    bottom: 0;
    right: 0;
    width: 1.5px;
    height: 100%;
  }

  .geo-dot {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-silver);
    transform: translate(-50%, -50%);
  }
  .geo-dot-ring {
    background: transparent;
    border: 1.5px solid var(--color-silver-dark);
    width: 8px;
    height: 8px;
  }

  /* ── Tick rule ────────────────────────────────────────────────────────── */

  .tick-rule {
    display: flex;
    align-items: flex-end;
    height: 20px;
    border-top: 1px solid var(--global-divider-color);
    position: relative;
    padding: 0 2rem;
    gap: 0;
  }

  .tick {
    flex: 1;
    display: block;
    height: 6px;
    border-right: 1px solid var(--global-divider-color);
  }

  .tick[data-major] {
    height: 12px;
    border-right-color: var(--color-silver-dark);
  }

  /* ══ STATS BAR ══════════════════════════════════════════════════════════ */

  .stats-bar {
    display: flex;
    align-items: center;
    padding-top: 1.75rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--global-divider-color);
    gap: 0;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.5rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .stat-item:first-child {
    padding-left: 0;
  }

  .stat-item:hover {
    opacity: 0.7;
  }

  .stat-div {
    width: 1px;
    height: 2rem;
    background: var(--global-divider-color);
    flex-shrink: 0;
  }

  .stat-n {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(135deg, var(--global-text-color) 40%, var(--color-silver) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .stat-l {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-silver-dark);
  }

  .stat-social {
    margin-left: auto;
    padding-left: 2rem;
    display: flex;
    align-items: center;
    color: var(--color-silver);
  }

  /* ══ TWO-COLUMN SECTIONS ════════════════════════════════════════════════ */

  .two-col-section {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 3.5rem;
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--global-divider-color);
  }

  @media (max-width: 700px) {
    .two-col-section {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .col-label {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.15rem;
  }

  .col-tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-silver-dark);
    text-decoration: none;
  }

  .col-tag-link:hover {
    color: var(--global-text-color);
  }

  .col-tag-rule {
    width: 1.5px;
    flex: 1;
    max-height: 120px;
    background: linear-gradient(to bottom, var(--color-silver-dark), transparent);
    border-radius: 1px;
  }

  .col-more {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-silver-dark);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .col-more:hover {
    color: var(--global-text-color);
  }

  .col-body {
    font-size: 1rem;
    line-height: 1.78;
  }

  /* ── News table ──────────────────────────────────────────────────────── */

  .news-tbl {
    width: 100%;
    border-collapse: collapse;
  }

  .news-row {
    transition: background-color 0.15s ease;
  }
  .news-row:hover {
    background-color: var(--global-card-bg-color);
  }

  .news-date {
    padding: 0.7rem 1.5rem 0.7rem 0;
    vertical-align: top;
    white-space: nowrap;
    font-size: 0.75rem;
    color: var(--color-silver-dark);
    width: 120px;
    border-top: 1px solid var(--global-divider-color);
    font-variant-numeric: tabular-nums;
  }

  .news-body {
    padding: 0.7rem 0;
    font-size: 0.9rem;
    color: var(--global-text-color);
    border-top: 1px solid var(--global-divider-color);
  }

  .news-tbl tr:first-child .news-date,
  .news-tbl tr:first-child .news-body {
    border-top: none;
  }

  /* ── Publications list ───────────────────────────────────────────────── */

  .pub-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pub-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1rem 1rem 1.25rem;
    border-top: 1px solid var(--global-divider-color);
    border-left: 2px solid transparent;
    transition:
      border-left-color 0.2s ease,
      background-color 0.2s ease,
      padding-left 0.2s ease;
  }

  .pub-item:first-child {
    border-top: none;
  }

  .pub-item:hover {
    border-left-color: var(--color-silver);
    background-color: var(--global-card-bg-color);
    padding-left: 1.5rem;
  }

  .pub-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    border-radius: 2px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--color-silver-dark);
    color: var(--global-bg-color);
    align-self: flex-start;
    margin-bottom: 0.15rem;
    font-family: 'Space Grotesk', system-ui, sans-serif;
  }

  .pub-title {
    font-size: 0.93rem;
    font-weight: 600;
    color: var(--global-text-color);
    text-decoration: none;
    line-height: 1.45;
    transition: color 0.2s ease;
  }
  .pub-title:hover {
    color: var(--color-silver);
  }

  .pub-meta {
    font-size: 0.8rem;
    color: var(--color-silver-dark);
    line-height: 1.4;
  }

  /* ── Reduced motion ──────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .geo-ring,
    .geo-arc {
      animation: none;
    }
  }
</style>
