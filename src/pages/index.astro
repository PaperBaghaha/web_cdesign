---
import Layout from '../layouts/Layout.astro';
import pubs from '../data/publications.json';
import news from '../data/news.json';

const recentPubs = pubs.slice(0, 6);
const recentNews = news.slice(0, 3);

// group pubs by year
const pubsByYear: Record<string, typeof pubs> = {};
pubs.forEach(p => { const y = String(p.year||'Unknown'); if(!pubsByYear[y]) pubsByYear[y]=[]; pubsByYear[y].push(p); });
const pubYears = Object.keys(pubsByYear).sort((a,b)=>Number(b)-Number(a));

// group news by year
const newsByYear: Record<string, typeof news> = {};
news.forEach(n => { const y = n.date ? n.date.slice(0,4) : 'Unknown'; if(!newsByYear[y]) newsByYear[y]=[]; newsByYear[y].push(n); });
const newsYears = Object.keys(newsByYear).sort((a,b)=>Number(b)-Number(a));

const sections = [
  { id:'hero',         label:'HOME'         },
  { id:'research',     label:'RESEARCH'     },
  { id:'people',       label:'PEOPLE'       },
  { id:'publications', label:'PUBLICATIONS' },
  { id:'news',         label:'NEWS'         },
  { id:'contact',      label:'CONTACT'      },
];

const areas = [
  { code:'01', title:'AR / VR / MR',           desc:'Immersive skill transfer, spatial computing, and mixed reality interfaces for the future of work and education.', detail:'We develop AR/VR platforms like SkillXR that enable knowledge transfer in industrial and educational contexts. Our work spans holographic overlays, gesture-driven interfaces, and full-body immersive environments across manufacturing, surgery, and STEM learning.' },
  { code:'02', title:'AI & Computer Vision',    desc:'Visual understanding, pose estimation, and generative models applied to design and manufacturing.', detail:'Our CV research tackles real-time object recognition, 6-DoF pose estimation, hand and body tracking, and generative AI for shape synthesis. We deploy these systems in robotics pipelines and smart factory environments.' },
  { code:'03', title:'Human-Shape Interaction', desc:'Mid-air gestures, multi-touch, and freehand sketch interaction with 3D objects and digital environments.', detail:'We pioneer sketch-based 3D modeling, mid-air dexterous manipulation, and touch+pen hybrid interaction. Our tools let designers fluidly reshape geometry using natural hand motion rather than menus and parameters.' },
  { code:'04', title:'Geometric Deep Learning', desc:'Machine learning on 3D point clouds, meshes, and implicit surfaces for shape analysis and reconstruction.', detail:'We train neural networks directly on 3D representations — point clouds, SDFs, and meshes — for tasks like part segmentation, shape completion, and cross-modal retrieval between sketches and 3D models.' },
  { code:'05', title:'Smart Product Design',    desc:'Intelligent wearables, robotics, and IoT devices that sense, adapt, and collaborate with their users.', detail:'We build sensor-rich wearables and collaborative robots that learn user intent and context. Projects include EMG-driven prosthetics, tactile feedback gloves, and autonomous co-design agents.' },
  { code:'06', title:'Design Learning',         desc:'Educational platforms, maker culture, outreach programs, and next-generation design thinking frameworks.', detail:'We create curriculum, tools, and communities that democratize engineering design — from MCB maker programs for K-12 students to AI-assisted design coaching platforms used in Purdue courses and globally.' },
];

const people = [
  { name:'Karthik Ramani',  role:'Principal Investigator', tag:'PI'  },
  { name:'Jingyu Shi',      role:'PhD Student',            tag:'PhD' },
  { name:'Rahul Jain',      role:'PhD Student',            tag:'PhD' },
  { name:'Runlin Duan',     role:'PhD Student',            tag:'PhD' },
  { name:'Yuzhao Chen',     role:'PhD Student',            tag:'PhD' },
  { name:'Dizhi Ma',        role:'PhD Student',            tag:'PhD' },
  { name:'Hyungjun Doh',    role:'PhD Student',            tag:'PhD' },
  { name:'Mayank Patel',    role:'PhD Student',            tag:'PhD' },
  { name:'Chenfei Zhu',     role:'PhD Student',            tag:'PhD' },
  { name:'Seunggeun Chi',   role:'PhD Student',            tag:'PhD' },
  { name:'Ziyi Liu',        role:'PhD Student',            tag:'PhD' },
  { name:'Ananya Ipsita',   role:'PhD Student',            tag:'PhD' },
  { name:'Fengming He',     role:'PhD Student',            tag:'PhD' },
  { name:'Pashin Raja',     role:'PhD Student',            tag:'PhD' },
  { name:'Xiyun Hu',        role:'PhD Student',            tag:'PhD' },
];

function initials(n:string){ return n.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(); }
---
<Layout title="Home" isHome={true}>

<aside class="sidebar" id="sidebar">
  <div class="sb-track">
    {sections.map((s) => (
      <a href={`#${s.id}`} class="sb-item" data-section={s.id}>
        <span class="sb-pip"></span>
        <span class="sb-label mono">{s.label}</span>
      </a>
    ))}
  </div>
  <div class="sb-rule"></div>
</aside>

