/* ── Scroll reveals — play AND reverse ── */
function revealSection(id:string, items:string, fromX:number, fromY:number){
  gsap.fromTo(items,
    {autoAlpha:0,x:fromX,y:fromY},
    {autoAlpha:1,x:0,y:0,duration:.6,stagger:.07,ease:'power2.out',
     scrollTrigger:{trigger:'#'+id,start:'top 75%',end:'bottom 20%',
       toggleActions:'play none none none'}});
}
revealSection('research', '.scene-left, .area-row', -40, 0);
revealSection('people',   '.people-grid .person-card', 0, 40);
revealSection('publications', '.pub-header, .pub-row', 0, 30);
revealSection('news',     '.news-card', 0, 40);
revealSection('contact',  '.contact-row', -30, 0);

/* ── Sidebar active ── */
['hero','research','people','publications','news','contact'].forEach(function(id){
  ScrollTrigger.create({trigger:'#'+id,start:'top center',end:'bottom center',
    onEnter:function(){setActive(id);},onEnterBack:function(){setActive(id);}});
});
function setActive(id:string){
  document.querySelectorAll('.sb-item').forEach(function(el){
    el.classList.toggle('active',(el as HTMLElement).dataset.section===id);
  });
}

/* ── Full panel logic ── */
function setupPanel(expandBtnId, panelId, rowSel, countId, typeLabel) {
  var expandBtn = document.getElementById(expandBtnId);
  var panel = document.getElementById(panelId);
  if (!expandBtn || !panel) return;

  function openPanel() {
    panel.classList.add('open');
    panel.setAttribute('aria-hidden','false');
    expandBtn.classList.add('open');
    var lbl = expandBtn.querySelector('.va-label');
    if (lbl) lbl.textContent = 'SHOW LESS';
    setTimeout(function(){ panel.scrollIntoView({behavior:'smooth',block:'start'}); }, 60);
  }
  function closePanel() {
    panel.classList.remove('open');
    panel.setAttribute('aria-hidden','true');
    expandBtn.classList.remove('open');
    var lbl = expandBtn.querySelector('.va-label');
    if (lbl) lbl.textContent = expandBtn.getAttribute('data-closed-label') || 'VIEW ALL';
  }

  // store original label
  var origLabel = expandBtn.querySelector('.va-label')?.textContent || '';
  expandBtn.setAttribute('data-closed-label', origLabel);
  expandBtn.addEventListener('click', function() {
    panel.classList.contains('open') ? closePanel() : openPanel();
  });

  // minimize button inside panel
  var minBtn = panel.querySelector('.fp-minimize-btn');
  if (minBtn) minBtn.addEventListener('click', function() {
    closePanel();
    setTimeout(function(){ expandBtn.scrollIntoView({behavior:'smooth',block:'center'}); }, 60);
  });

  // year toggle accordion
  panel.querySelectorAll('.fp-year-toggle').forEach(function(toggle) {
    toggle.addEventListener('click', function() {
      var grp = toggle.closest('.fp-year-group');
      var wasOpen = grp.classList.contains('open');
      grp.classList.toggle('open', !wasOpen);
      // sync sidebar
      var grpId = grp.id;
      panel.querySelectorAll('.fp-year-link').forEach(function(a) {
        a.classList.toggle('active', a.getAttribute('data-target') === grpId && !wasOpen);
      });
    });
  });

  // sidebar year buttons → expand group + scroll
  panel.querySelectorAll('.fp-year-link').forEach(function(a) {
    a.addEventListener('click', function() {
      var target = a.getAttribute('data-target');
      var grp = document.getElementById(target);
      if (!grp) return;
      if (!grp.classList.contains('open')) grp.classList.add('open');
      panel.querySelectorAll('.fp-year-link').forEach(function(x){ x.classList.remove('active'); });
      a.classList.add('active');
      setTimeout(function(){ grp.scrollIntoView({behavior:'smooth',block:'start'}); }, 50);
    });
  });

  // search
  var searchEl = panel.querySelector('.fp-search');
  var countEl = document.getElementById(countId);
  if (searchEl) {
    searchEl.addEventListener('input', function() {
      var q = this.value.toLowerCase().trim();
      var visible = 0;
      panel.querySelectorAll('.fp-year-group').forEach(function(grp) {
        var rows = grp.querySelectorAll(rowSel);
        var groupMatch = false;
        rows.forEach(function(row) {
          var match = !q || (row.getAttribute('data-text')||'').toLowerCase().includes(q);
          row.classList.toggle('hidden', !match);
          if (match) { visible++; groupMatch = true; }
        });
        grp.classList.toggle('all-hidden', !groupMatch);
        if (q && groupMatch) grp.classList.add('open');
      });
      if (countEl) countEl.textContent = visible + ' ' + typeLabel;
    });
  }
}

setupPanel('pub-expand',  'pub-panel',  '.fp-pub-row',  'pub-search-count',  'PUBLICATIONS');
setupPanel('news-expand', 'news-panel', '.fp-news-row', 'news-search-count', 'NEWS ITEMS');

/* ── MORE buttons ── */
document.querySelectorAll('.ar-more-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var idx = (btn as HTMLElement).getAttribute('data-idx');
    var panel = document.getElementById('detail-' + idx);
    if (!panel) return;
    var isOpen = panel.classList.contains('open');
    panel.classList.toggle('open', !isOpen);
    (btn as HTMLElement).classList.toggle('expanded', !isOpen);
    var label = btn.querySelector('.ar-btn-label');
    if (label) label.textContent = isOpen ? 'MORE' : 'LESS';
  });
});

/* ── Parallax ── */
gsap.to('#hero .scene-svg',{y:-70,ease:'none',scrollTrigger:{trigger:'#hero',scrub:1.5}});
</script>
