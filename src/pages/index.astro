<!-- ══ PUB FULL PANEL ════════════════════════════════════ -->
<div class="full-panel" id="pub-panel" aria-hidden="true">
  <div class="fp-topbar">
    <span class="fp-topbar-title mono">{pubs.length} PUBLICATIONS</span>
    <button class="fp-minimize-btn" data-panel="pub-panel" data-expand="pub-expand" data-label={`VIEW ALL ${pubs.length} PUBLICATIONS`}>
      MINIMIZE <span>−</span>
    </button>
  </div>
  <div class="fp-inner">
    <aside class="fp-years">
      <span class="label">BY YEAR</span>
      {pubYears.map(y=>(
        <button class="fp-year-link mono" data-target={`pub-yr-${y}`}>
          <span>{y}</span><span class="fp-ycount">{pubsByYear[y].length}</span>
        </button>
      ))}
    </aside>
    <div class="fp-list" id="pub-full-list">
      {pubYears.map(y=>(
        <div class="fp-year-group" id={`pub-yr-${y}`}>
          <button class="fp-year-toggle">
            <span class="fyt-year mono">{y}</span>
            <span class="fyt-count mono">{pubsByYear[y].length} papers</span>
            <span class="fyt-icon">+</span>
          </button>
          <div class="fyg-rows">
            {pubsByYear[y].map((p,i)=>(
              <div class="pub-row fp-pub-row" data-text={`${p.title} ${p.authors.join(' ')} ${p.year}`}>
                <span class="pub-i mono">{String(i+1).padStart(2,'0')}</span>
                <span class="pub-y mono">{p.year||'—'}</span>
                <div class="pub-bd">
                  <span class="pub-t">{p.title}</span>
                  {p.authors.length>0&&<span class="pub-a mono">{p.authors.slice(0,3).join(' · ')}</span>}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="fp-search-col">
      <span class="label">SEARCH</span>
      <input type="text" id="pub-search" class="search-input fp-search" placeholder="Title, author, year…"/>
      <p class="fp-search-hint mono" id="pub-search-count">{pubs.length} PUBLICATIONS</p>
    </div>
  </div>
</div>

