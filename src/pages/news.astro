---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { withBase } from '@utils/base';
import { getCollection } from 'astro:content';

const announcements = (await getCollection('announcements'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  });

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

/** Resolve a bare filename against /assets/img/news/, or pass a full URL through. */
const imageSrc = (image: string) =>
  image.startsWith('http') ? image : withBase(`/assets/img/news/${image}`);

/** Internal article page for an announcement. */
const articleHref = (item: (typeof announcements)[number]) =>
  withBase(`/news/${item.data.slug ?? item.id}/`);
---

<Page title="News" description={`News and announcements from ${site.author.name}`}>
  <div class="post">
    <header class="post-header" data-reveal>
      <h1 class="post-title">news</h1>
      <p class="post-description" style="color: var(--global-text-color-light);">
        Updates, awards, and announcements from the lab.
      </p>
    </header>
    <article>
      {
        announcements.length === 0 ? (
          <p style="color: var(--global-text-color-light);">No announcements yet.</p>
        ) : (
          <ul class="news-list">
            {announcements.map((item) => {
              const { title, image, alt, excerpt } = item.data;
              const href = articleHref(item);
              return (
                <li class="news-item">
                  {image && (
                    <a class="news-thumb" href={href} tabindex="-1" aria-hidden="true">
                      <img src={imageSrc(image)} alt={alt ?? ''} loading="lazy" />
                    </a>
                  )}
                  <div class="news-body">
                    <h2 class="news-title">
                      <a href={href}>{title ?? item.id}</a>
                    </h2>
                    <p class="news-date">{formatDate(item.data.date)}</p>
                    {excerpt && <p class="news-excerpt">{excerpt}</p>}
                  </div>
                </li>
              );
            })}
          </ul>
        )
      }
    </article>
  </div>
</Page>

<style>
  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-bottom: 0;
  }

  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .news-item {
    display: flex;
    align-items: center;
    gap: 2.75rem;
    padding: 2.75rem 0;
    border-bottom: 1px solid var(--global-divider-color);
  }

  .news-thumb {
    flex: 0 0 42%;
    max-width: 42%;
    display: block;
    overflow: hidden;
    border-radius: 10px;
  }

  .news-thumb img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .news-thumb:hover img {
    transform: scale(1.04);
  }

  .news-body {
    flex: 1 1 auto;
    min-width: 0;
  }

  .news-title {
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 0.6rem;
    font-family: var(--font-sans);
  }

  .news-title a {
    color: var(--global-text-color);
    text-decoration: none;
  }

  .news-title a:hover {
    color: var(--global-theme-color);
  }

  .news-date {
    font-size: 0.95rem;
    font-style: italic;
    color: var(--global-text-color-light);
    margin: 0 0 0.9rem;
  }

  .news-excerpt {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--global-text-color-light);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .news-item {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
      padding: 1.75rem 0;
    }

    .news-thumb,
    .news-thumb img {
      width: 100%;
      max-width: 100%;
      flex-basis: auto;
    }

    .news-thumb img {
      height: 220px;
    }

    .news-title {
      font-size: 1.4rem;
    }
  }
</style>
